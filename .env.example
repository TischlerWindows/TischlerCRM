# === Frontend (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:4000

# === Backend (Fastify) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# === Application ===
NODE_ENV=development
PORT=4000
FRONTEND_PORT=3000

# === Support Tickets ===
# Number of days to retain unattached error logs. Errors linked to a ticket are
# retained indefinitely. Retention sweep runs probabilistically on each write.
ERROR_LOG_RETENTION_DAYS=30

# === Notifications ===
# Number of days to retain notifications (read or unread). Sweep runs
# probabilistically (~1%) on each notify() call.
NOTIFICATION_RETENTION_DAYS=90

# === Encryption (for securing integration tokens at rest) ===
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to JWT_SECRET in dev if not set.
# ENCRYPTION_KEY=your-64-char-hex-string

# === Optional: Storage & Integrations ===
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# S3_BUCKET_NAME=your-bucket
# SLACK_WEBHOOK_URL=
# SENDGRID_API_KEY=

# === External Integration API keys are managed via the UI ===
# Go to Settings > Integrations to configure Google Maps, Dropbox, Outlook, etc.
# Keys are encrypted at rest using ENCRYPTION_KEY above.
